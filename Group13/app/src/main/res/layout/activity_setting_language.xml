<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pic_background2">

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/imageButtonBack"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_back"
                app:tint="@color/darkblue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:fontFamily="@font/bevietnampro_regular"
                android:text="Select Language"
                android:textColor="@color/darkblue"
                android:textSize="20sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp"
            android:layout_marginTop="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="20dp">

                <RadioGroup
                    android:id="@+id/rgLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <!-- Vietnamese -->
                    <LinearLayout
                        android:id="@+id/layoutVietnamese"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_soft_card"
                        android:backgroundTint="@color/white"
                        android:layout_marginBottom="12dp"
                        android:elevation="4dp"
                        android:layout_marginHorizontal="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="24dp"
                            android:src="@drawable/flag_vietnam"
                            android:contentDescription="Vietnam Flag"
                            android:layout_marginEnd="12dp"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:id="@+id/tvVietnamese"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Vietnamese"
                            android:textSize="16sp"
                            android:textColor="@color/darkblue"
                            android:fontFamily="@font/bevietnampro_regular"
                            android:layout_weight="1"/>

                        <RadioButton
                            android:id="@+id/rbVietnamese"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/darkblue"/>
                    </LinearLayout>

                    <!-- English -->
                    <LinearLayout
                        android:id="@+id/layoutEnglish"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_soft_card"
                        android:backgroundTint="@color/white"
                        android:layout_marginBottom="12dp"
                        android:elevation="4dp"
                        android:layout_marginHorizontal="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="24dp"
                            android:src="@drawable/flag_uk"
                            android:contentDescription="UK Flag"
                            android:layout_marginEnd="12dp"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:id="@+id/tvEnglish"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="English"
                            android:textSize="16sp"
                            android:textColor="@color/darkblue"
                            android:fontFamily="@font/bevietnampro_regular"
                            android:layout_weight="1"/>

                        <RadioButton
                            android:id="@+id/rbEnglish"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/darkblue"/>
                    </LinearLayout>

                </RadioGroup>

                <TextView
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="30dp"
                    android:text="Save"
                    android:fontFamily="@font/bevietnampro_semibold"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="@color/darkblue"
                    android:gravity="center"
                    android:background="@drawable/custom_edittext"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="5dp"
                    android:text="Cancel"
                    android:textSize="16sp"
                    android:textColor="@color/darkblue"
                    app:cornerRadius="30dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/darkblue"
                    app:backgroundTint="@color/white"
                    android:fontFamily="@font/bevietnampro_medium"
                    />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <!-- BOTTOM NAVIGATION BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_house"
                app:tint="@color/darkblue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bevietnampro_regular"
                android:text="Home"
                android:textColor="@color/darkblue"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Project -->
        <LinearLayout
            android:id="@+id/navProject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/navHome"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/navAttendance"
            app:layout_constraintHorizontal_chainStyle="spread">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_folder"
                app:tint="@color/darkblue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bevietnampro_regular"
                android:text="Project"
                android:textColor="@color/darkblue"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Attendance -->
        <LinearLayout
            android:id="@+id/navAttendance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/navProject"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/navAccount">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/darkblue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bevietnampro_regular"
                android:text="Attendance"
                android:textColor="@color/darkblue"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Setting -->
        <LinearLayout
            android:id="@+id/navAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_gear"
                app:tint="@color/darkblue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bevietnampro_regular"
                android:text="Setting"
                android:textColor="@color/darkblue"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>