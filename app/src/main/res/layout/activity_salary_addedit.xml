<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Toolbar cố định -->
    <LinearLayout
        android:id="@+id/toolbarLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/imageButtonBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_back"
            app:tint="@color/darkblue" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/bevietnampro_regular"
            android:text="@string/welcomeback"
            android:textColor="@color/darkblue"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Nội dung cuộn -->
    <ScrollView
        android:id="@+id/scrollViewSalary"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Tiêu đề -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:layout_gravity="left"
                android:fontFamily="@font/bevietnampro_bold"
                android:text="@string/employee_salary"
                android:textColor="@color/darkblue"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Employee ID -->
            <EditText
                android:id="@+id/etEmployeeId"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/custom_edittext"
                android:hint="@string/employee_id"
                android:padding="10dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Employee Name -->
            <EditText
                android:id="@+id/etEmployeeName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/custom_edittext"
                android:hint="@string/employee_name"
                android:padding="10dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Position -->
            <AutoCompleteTextView
                android:id="@+id/autoPosition"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext"
                android:fontFamily="@font/bevietnampro_regular"
                android:hint="@string/position"
                android:padding="10dp"
                android:focusable="true"
                android:clickable="true"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:drawableEnd="@drawable/ic_arrow_drop_down"
                android:drawablePadding="10dp" />

            <!-- Base Salary -->
            <EditText
                android:id="@+id/etBaseSalary"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/custom_edittext"
                android:hint="@string/base_salary"
                android:inputType="number"
                android:padding="10dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Work Hours -->
            <EditText
                android:id="@+id/etWorkHours"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/custom_edittext"
                android:hint="@string/standard_working_hours"
                android:inputType="number"
                android:padding="10dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Salary Item List Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSalaryItems"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/last_paycheck"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkblue"
                    android:fontFamily="@font/bevietnampro_semibold" />

                <ImageButton
                    android:id="@+id/btnAddItem"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/transparent"
                    android:src="@drawable/ic_add"
                    android:contentDescription="Add salary item"
                    app:tint="@color/lightblue" />
            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSalary"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="8dp"
                tools:listitem="@layout/item_salary" />

            <!-- Total -->
            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/total"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/darkblue"
                android:fontFamily="@font/bevietnampro_semibold"
                android:gravity="end"
                android:padding="8dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="15dp">

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="160dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="8dp"
                    android:backgroundTint="@color/white"
                    android:text="@string/cancel"
                    android:textColor="@color/darkblue"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="160dp"
                    android:layout_height="55dp"
                    android:backgroundTint="@color/darkblue"
                    android:text="@string/save"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Delete -->
            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#E53935"
                android:text="@string/delete_current_payslip"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
