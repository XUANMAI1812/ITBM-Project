<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_soft_card"
    android:backgroundTint="@color/white"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Tiêu đề task + checkbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/checkboxDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/darkblue"
                android:focusable="false"
                android:clickable="true"
                android:contentDescription="Mark task done"/>

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/task_title"
                android:textColor="@color/darkblue"
                android:textSize="16sp"
                android:fontFamily="@font/bevietnampro_bold"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Người phụ trách + deadline -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgAssignee"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/pic_placeholder"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_icon_circle"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvAssignee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nguyen Van A"
                android:textColor="@color/gray"
                android:textSize="14sp"
                android:fontFamily="@font/bevietnampro_regular" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/lightblue"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Nov 2025"
                android:textColor="@color/gray"
                android:textSize="14sp"
                android:fontFamily="@font/bevietnampro_regular"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>